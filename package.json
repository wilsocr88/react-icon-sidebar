{
  "name": "react-icon-sidebar",
  "version": "2.0.1",
  "description": "A responsive iconographic side-menu component for React apps",
  "main": "dist/react-icon-sidebar.umd.js",
  "module": "dist/react-icon-sidebar.es.js",
  "exports": {
    ".": {
      "import": "./dist/react-icon-sidebar.es.js",
      "require": "./dist/react-icon-sidebar.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Craig Wilson <wilsocr88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilsocr88/react-icon-sidebar.git"
  },
  "scripts": {
    "build": "vite build",
    "test": "jest",
    "demo": "vite --config demo/vite.config.js",
    "demo:build": "vite build --config demo/vite.config.js",
    "demo:preview": "vite preview --config demo/vite.config.js"
  },
  "dependencies": {
    "@babel/register": "^7.24.6",
    "prop-types": "^15.8.1",
    "react-icons": "5.2.1"
  },
  "peerDependencies": {
    "react": ">=16.13.1"
  },
  "devDependencies": {
    "@babel/preset-env": "7.24.7",
    "@babel/preset-react": "7.24.7",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": ">=16.13.1",
    "react-dom": ">=16.13.1",
    "react-icons": "5.2.1",
    "vite": "^8.1.3"
  },
  "jest": {
    "moduleNameMapper": {
      "\\.(css)$": "identity-obj-proxy"
    }
  }
}